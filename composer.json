{
    "name": "webrek/laravel-outbox",
    "description": "Transactional outbox for Laravel: stage messages inside your database transaction and relay them reliably with retries and backoff.",
    "keywords": [
        "laravel",
        "laravel-package",
        "outbox",
        "transactional-outbox",
        "exactly-once",
        "events",
        "webhooks",
        "messaging",
        "reliability",
        "eventual-consistency"
    ],
    "homepage": "https://github.com/webrek/laravel-outbox",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Victor Hernandez",
            "email": "victor@arturohernandez.com.mx"
        }
    ],
    "support": {
        "issues": "https://github.com/webrek/laravel-outbox/issues",
        "source": "https://github.com/webrek/laravel-outbox",
        "security": "https://github.com/webrek/laravel-outbox/security/advisories/new"
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "infection/infection": "^0.29",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Webrek\\Outbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webrek\\Outbox\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webrek\\Outbox\\OutboxServiceProvider"
            ],
            "aliases": {
                "Outbox": "Webrek\\Outbox\\Facades\\Outbox"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "pint": "pint",
        "pint:check": "pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
